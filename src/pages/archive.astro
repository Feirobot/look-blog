---
import BaseLayout from '../layouts/BaseLayout.astro';
import Layout from '../components/Layout.astro';
import { getPublishedPosts } from '../utils/posts';
import { formatDate } from '../utils/date';

const posts = await getPublishedPosts();

// Group posts by year and month
const postsByDate = posts.reduce((acc, post) => {
  const year = post.data.pubDate.getFullYear();
  const month = post.data.pubDate.toLocaleString('zh-CN', { month: 'long' });
  
  if (!acc[year]) {
    acc[year] = {};
  }
  if (!acc[year][month]) {
    acc[year][month] = [];
  }
  acc[year][month].push(post);
  
  return acc;
}, {} as Record<number, Record<string, typeof posts>>);

// Sort years descending
const sortedYears = Object.keys(postsByDate).sort((a, b) => b - a).map(Number);
---

<BaseLayout title="文章归档 | 我的博客" description="所有文章归档">
  <Layout>
    <div class="max-w-4xl mx-auto">
      <header class="mb-12">
        <h1 class="text-2xl font-bold text-[var(--theme-text-primary)] mb-4">
          文章归档
        </h1>
        <p class="text-lg text-[var(--theme-text-muted)]">
          共 {posts.length} 篇文章
        </p>
      </header>
      
      <div class="space-y-12">
        {sortedYears.map((year) => (
          <section>
            <h2 class="text-2xl font-bold text-[var(--theme-text-primary)] mb-6 flex items-center gap-3">
              {year}
              <span class="text-sm font-normal text-[var(--theme-text-muted)]">
                {postsByDate[year][Object.keys(postsByDate[year])[0]].length + 
                 Object.values(postsByDate[year]).reduce((sum, monthPosts) => sum + monthPosts.length, 0) - 
                 postsByDate[year][Object.keys(postsByDate[year])[0]].length} 篇
              </span>
            </h2>
            
            <div class="space-y-6">
              {Object.entries(postsByDate[year]).map(([month, monthPosts]) => (
                <div>
                  <h3 class="text-lg font-semibold text-[var(--theme-text-secondary)] mb-4">
                    {month}
                  </h3>
                  <ul class="space-y-3">
                    {monthPosts.map((post) => (
                      <li>
                        <a
                          href={`/posts/${post.slug}/`}
                          class="block group"
                        >
                          <div class="flex items-start gap-4">
                            <time class="text-sm text-[var(--theme-text-muted)] min-w-[100px]">
                              {formatDate(post.data.pubDate)}
                            </time>
                            <div>
                              <h4 class="text-[var(--theme-text-primary)] group-hover:text-[var(--theme-accent)] transition-colors font-medium">
                                {post.data.title}
                              </h4>
                              {post.data.tags.length > 0 && (
                                <div class="flex flex-wrap gap-1 mt-1">
                                  {post.data.tags.slice(0, 3).map((tag) => (
                                    <span class="text-xs text-[var(--theme-text-muted)]">#{tag}</span>
                                  ))}
                                </div>
                              )}
                            </div>
                          </div>
                        </a>
                      </li>
                    ))}
                  </ul>
                </div>
              ))}
            </div>
          </section>
        ))}
      </div>
    </div>
  </Layout>
</BaseLayout>
