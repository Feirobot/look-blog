---
import { formatDate } from '../utils/date';
import type { CollectionEntry } from 'astro:content';

interface Props {
  post: CollectionEntry<'posts'>;
  featured?: boolean;
}

const { post, featured = false } = Astro.props;
---

<article
  class={`card card-hover group ${featured ? 'lg:col-span-2' : ''}`}
>
  <a href={`/posts/${post.slug}/`} class="block">
    <!-- Cover Image -->
    {post.data.cover && (
      <div class={`mb-4 overflow-hidden rounded-lg ${featured ? 'h-48 sm:h-64' : 'h-40'}`}>
        <img
          src={post.data.cover}
          alt={post.data.coverAlt || post.data.title}
          class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
          loading="lazy"
        />
      </div>
    )}
    
    <!-- Content -->
    <div>
      <!-- Title -->
      <h2 class={`font-bold text-[var(--theme-text-primary)] group-hover:text-[var(--theme-accent)] transition-colors ${featured ? 'text-2xl sm:text-3xl' : 'text-xl'}`}>
        {post.data.title}
      </h2>
      
      <!-- Excerpt -->
      <p class="text-[var(--theme-text-muted)] mt-2 line-clamp-2">
        {post.data.description}
      </p>
      
      <!-- Meta -->
      <div class="flex items-center gap-4 mt-4 text-sm text-[var(--theme-text-muted)]">
        <time datetime={post.data.pubDate.toISOString()}>
          {formatDate(post.data.pubDate)}
        </time>
        <span>·</span>
        <span>{Math.ceil(post.body.length / 1000)} 分钟阅读</span>
      </div>
      
      <!-- Tags -->
      {post.data.tags.length > 0 && (
        <div class="flex flex-wrap gap-2 mt-4">
          {post.data.tags.slice(0, 3).map((tag) => (
            <span class="tag">
              #{tag}
            </span>
          ))}
          {post.data.tags.length > 3 && (
            <span class="text-xs text-[var(--theme-text-muted)] py-1">
              +{post.data.tags.length - 3}
            </span>
          )}
        </div>
      )}
    </div>
  </a>
</article>
