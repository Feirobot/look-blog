---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Layout from '../../components/Layout.astro';
import PostList from '../../components/PostList.astro';

export async function getStaticPaths() {
  const posts = await getCollection('posts');
  const tags = new Set<string>();
  
  posts.forEach(({ data }) => {
    if (!data.draft) {
      data.tags.forEach((tag) => tags.add(tag));
    }
  });
  
  return Array.from(tags).map((tag) => ({
    params: { tag },
  }));
}

const { tag } = Astro.params;
const posts = (await getCollection('posts'))
  .filter(({ data }) => !data.draft && data.tags.includes(tag as string))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<BaseLayout
  title={`#${tag} | 我的博客`}
  description={`包含标签 #${tag} 的所有文章`}
>
  <Layout>
    <div class="max-w-4xl mx-auto">
      <header class="mb-12">
        <div class="flex items-center gap-3 mb-4">
          <span class="text-4xl">#</span>
          <h1 class="text-2xl font-bold text-[var(--theme-text-primary)]">
            {tag}
          </h1>
        </div>
        <p class="text-lg text-[var(--theme-text-muted)]">
          共 {posts.length} 篇文章
        </p>
      </header>
      
      <PostList posts={posts} showCount={false} />
      
      {posts.length === 0 && (
        <div class="text-center py-12">
          <p class="text-[var(--theme-text-muted)]">该标签下暂无文章</p>
        </div>
      )}
    </div>
  </Layout>
</BaseLayout>
