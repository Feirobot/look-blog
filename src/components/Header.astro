---
import ThemeToggle from './ThemeToggle.astro';
import { SearchIcon, MenuIcon } from './Icons';
---

<header class="sticky top-0 z-50 glass border-b border-[var(--border-light)]">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16">
      <!-- Logo -->
      <a href="/" class="flex items-center gap-3 group">
        <div class="w-10 h-10 rounded-xl gradient-bg flex items-center justify-center text-white font-bold text-lg shadow-lg group-hover:shadow-xl transition-shadow">
          F
        </div>
        <span class="text-lg font-bold text-[var(--text-primary)] group-hover:text-[var(--accent)] transition-colors">
          Fei's Blog
        </span>
      </a>

      <!-- Desktop Navigation -->
      <nav class="hidden md:flex items-center gap-1">
        <a href="/" class="px-4 py-2 rounded-lg text-[var(--text-secondary)] hover:text-[var(--accent)] hover:bg-[var(--bg-secondary)] transition-all font-medium">
          首页
        </a>
        <a href="/archive/" class="px-4 py-2 rounded-lg text-[var(--text-secondary)] hover:text-[var(--accent)] hover:bg-[var(--bg-secondary)] transition-all font-medium">
          归档
        </a>
        <a href="/tags/" class="px-4 py-2 rounded-lg text-[var(--text-secondary)] hover:text-[var(--accent)] hover:bg-[var(--bg-secondary)] transition-all font-medium">
          标签
        </a>
        <a href="/categories/" class="px-4 py-2 rounded-lg text-[var(--text-secondary)] hover:text-[var(--accent)] hover:bg-[var(--bg-secondary)] transition-all font-medium">
          分类
        </a>
        <a href="/about/" class="px-4 py-2 rounded-lg text-[var(--text-secondary)] hover:text-[var(--accent)] hover:bg-[var(--bg-secondary)] transition-all font-medium">
          关于
        </a>
      </nav>

      <!-- Right Side -->
      <div class="flex items-center gap-2">
        <!-- Search -->
        <a href="/search/" class="p-2 rounded-lg text-[var(--text-muted)] hover:text-[var(--accent)] hover:bg-[var(--bg-secondary)] transition-all" aria-label="搜索">
          <span set:html={SearchIcon()} />
        </a>
        
        <!-- Theme Toggle -->
        <ThemeToggle />
        
        <!-- Mobile Menu Button -->
        <button id="mobile-menu-btn" class="md:hidden p-2 rounded-lg text-[var(--text-muted)] hover:text-[var(--accent)] hover:bg-[var(--bg-secondary)] transition-all" aria-label="菜单">
          <span set:html={MenuIcon()} />
        </button>
      </div>
    </div>
  </div>

  <!-- Mobile Navigation -->
  <nav id="mobile-menu" class="md:hidden hidden border-t border-[var(--border-light)] bg-[var(--bg-primary)]">
    <div class="px-4 py-3 space-y-1">
      <a href="/" class="block px-4 py-2.5 rounded-lg text-[var(--text-secondary)] hover:bg-[var(--bg-secondary)] hover:text-[var(--accent)] transition-all font-medium">
        首页
      </a>
      <a href="/archive/" class="block px-4 py-2.5 rounded-lg text-[var(--text-secondary)] hover:bg-[var(--bg-secondary)] hover:text-[var(--accent)] transition-all font-medium">
        归档
      </a>
      <a href="/tags/" class="block px-4 py-2.5 rounded-lg text-[var(--text-secondary)] hover:bg-[var(--bg-secondary)] hover:text-[var(--accent)] transition-all font-medium">
        标签
      </a>
      <a href="/categories/" class="block px-4 py-2.5 rounded-lg text-[var(--text-secondary)] hover:bg-[var(--bg-secondary)] hover:text-[var(--accent)] transition-all font-medium">
        分类
      </a>
      <a href="/about/" class="block px-4 py-2.5 rounded-lg text-[var(--text-secondary)] hover:bg-[var(--bg-secondary)] hover:text-[var(--accent)] transition-all font-medium">
        关于
      </a>
    </div>
  </nav>
</header>
