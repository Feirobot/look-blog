---
import BaseLayout from '../layouts/BaseLayout.astro';
import PostList from '../components/PostList.astro';
import { getPublishedPosts } from '../utils/posts';

const posts = await getPublishedPosts();
const featuredPost = posts[0];
const recentPosts = posts.slice(0, 3);
---

<BaseLayout title="首页" description="个人博客 - 技术文章与学习笔记">
  <!-- Hero Section -->
  <section class="relative overflow-hidden py-16 sm:py-24">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h1 class="text-4xl sm:text-5xl font-bold mb-6">
        <span class="text-gradient">记录技术成长</span>
        <br />
        <span class="text-[var(--text-primary)]">分享编程心得</span>
      </h1>
      <p class="text-lg text-[var(--text-muted)] max-w-2xl mx-auto mb-8">
        这里是 Fei 的个人博客，专注于 Web 开发、前端工程化和编程技巧分享。
        每一篇文章都是学习与实践的总结。
      </p>
      <div class="flex items-center justify-center gap-4">
        <a href="/archive/" class="btn btn-primary px-6 py-3">
          浏览所有文章
          <svg class="ml-2 w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
          </svg>
        </a>
        <a href="/about/" class="btn btn-secondary">
          关于我
        </a>
      </div>
    </div>
  </section>

  <!-- Featured Post -->
  {featuredPost && (
    <section class="py-12">
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
        <h2 class="text-2xl font-bold mb-6 text-[var(--text-primary)]">精选文章</h2>
        <article class="card card-hover group cursor-pointer" onclick="window.location.href='/posts/{featuredPost.slug}/'">
          <div class="grid md:grid-cols-2 gap-6">
            {featuredPost.data.cover && (
              <div class="h-48 md:h-full overflow-hidden rounded-xl">
                <img
                  src={featuredPost.data.cover}
                  alt={featuredPost.data.coverAlt || featuredPost.data.title}
                  class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                  loading="lazy"
                />
              </div>
            )}
            <div class="flex flex-col justify-center">
              <h3 class="text-2xl font-bold text-[var(--text-primary)] group-hover:text-[var(--accent)] transition-colors mb-3">
                {featuredPost.data.title}
              </h3>
              <p class="text-[var(--text-secondary)] mb-4 line-clamp-3">
                {featuredPost.data.description}
              </p>
              <div class="flex items-center gap-4 text-sm text-[var(--text-muted)]">
                <time>{new Date(featuredPost.data.pubDate).toLocaleDateString('zh-CN')}</time>
                <span>·</span>
                <span>{Math.ceil(featuredPost.body.length / 1000)} 分钟阅读</span>
              </div>
              {featuredPost.data.tags.length > 0 && (
                <div class="flex flex-wrap gap-2 mt-4">
                  {featuredPost.data.tags.slice(0, 3).map((tag) => (
                    <span class="tag">#{tag}</span>
                  ))}
                </div>
              )}
            </div>
          </div>
        </article>
      </div>
    </section>
  )}

  <!-- Recent Posts -->
  <section class="py-12 bg-[var(--bg-secondary)]">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-2xl font-bold mb-6 text-[var(--text-primary)]">最新文章</h2>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {recentPosts.map((post) => (
          <article class="card card-hover group cursor-pointer" onclick="window.location.href='/posts/{post.slug}/'">
            {post.data.cover && (
              <div class="h-40 overflow-hidden rounded-xl mb-4">
                <img
                  src={post.data.cover}
                  alt={post.data.coverAlt || post.data.title}
                  class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                  loading="lazy"
                />
              </div>
            )}
            <h3 class="text-lg font-bold text-[var(--text-primary)] group-hover:text-[var(--accent)] transition-colors mb-2 line-clamp-2">
              {post.data.title}
            </h3>
            <p class="text-sm text-[var(--text-secondary)] mb-3 line-clamp-2">
              {post.data.description}
            </p>
            <div class="flex items-center gap-3 text-xs text-[var(--text-muted)]">
              <time>{new Date(post.data.pubDate).toLocaleDateString('zh-CN')}</time>
              <span>·</span>
              <span>{Math.ceil(post.body.length / 1000)} 分钟阅读</span>
            </div>
            {post.data.tags.length > 0 && (
              <div class="flex flex-wrap gap-2 mt-3">
                {post.data.tags.slice(0, 2).map((tag) => (
                  <span class="tag">#{tag}</span>
                ))}
              </div>
            )}
          </article>
        ))}
      </div>
      <div class="text-center mt-8">
        <a href="/archive/" class="btn btn-secondary">
          查看全部文章
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
