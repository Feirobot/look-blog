---
// Search component with Pagefind integration
---

<div id="search" class="search-container">
  <!-- Search Input -->
  <div class="relative">
    <input
      type="text"
      id="search-input"
      placeholder="搜索文章..."
      class="w-full px-4 py-3 pl-12 rounded-xl border border-[var(--theme-border)] bg-[var(--theme-bg-primary)] text-[var(--theme-text-primary)] placeholder-[var(--theme-text-muted)] focus:outline-none focus:ring-2 focus:ring-[var(--theme-accent)] focus:border-transparent transition-all"
      autocomplete="off"
    />
    <svg
      class="absolute left-4 top-1/2 -translate-y-1/2 w-5 h-5 text-[var(--theme-text-muted)]"
      fill="none"
      stroke="currentColor"
      viewBox="0 0 24 24"
    >
      <path
        stroke-linecap="round"
        stroke-linejoin="round"
        stroke-width="2"
        d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"
      />
    </svg>
  </div>
  
  <!-- Search Results -->
  <div
    id="search-results"
    class="mt-4 hidden"
  >
    <div id="search-results-list" class="space-y-4"></div>
  </div>
  
  <!-- No Results -->
  <div
    id="search-no-results"
    class="mt-8 text-center hidden"
  >
    <p class="text-[var(--theme-text-muted)]">未找到匹配的结果</p>
  </div>
</div>

<script>
  interface PagefindResult {
    url: string;
    meta: {
      title: string;
      description?: string;
    };
    excerpt?: string;
  }
  
  // Initialize Pagefind
  async function initPagefind() {
    return await import('/pagefind/pagefind.js');
  }
  
  // Search function
  async function search(query: string) {
    if (!query.trim()) {
      hideResults();
      return;
    }
    
    try {
      const pf = await initPagefind();
      const results: PagefindResult[] = await pf.search(query);
      displayResults(results);
    } catch (error) {
      console.error('Search error:', error);
    }
  }
  
  // Display results
  function displayResults(results: any[]) {
    const resultsList = document.getElementById('search-results-list');
    const resultsContainer = document.getElementById('search-results');
    const noResults = document.getElementById('search-no-results');
    
    if (!resultsList || !resultsContainer || !noResults) return;
    
    if (results.length === 0) {
      resultsContainer.classList.add('hidden');
      noResults.classList.remove('hidden');
      return;
    }
    
    noResults.classList.add('hidden');
    resultsContainer.classList.remove('hidden');
    
    resultsList.innerHTML = results.map((result: any) => `
      <a href="${result.url}" class="block p-4 rounded-lg bg-[var(--theme-bg-secondary)] hover:bg-[var(--theme-accent-light)] transition-colors">
        <h3 class="text-lg font-semibold text-[var(--theme-text-primary)]">${result.meta.title}</h3>
        <p class="text-sm text-[var(--theme-text-muted)] mt-1">${result.meta.description || result.excerpt}</p>
      </a>
    `).join('');
  }
  
  // Hide results
  function hideResults() {
    const resultsContainer = document.getElementById('search-results');
    const noResults = document.getElementById('search-no-results');
    
    resultsContainer?.classList.add('hidden');
    noResults?.classList.add('hidden');
  }
  
  // Event listeners
  const searchInput = document.getElementById('search-input') as HTMLInputElement;
  let debounceTimer: NodeJS.Timeout;
  
  searchInput?.addEventListener('input', (e) => {
    clearTimeout(debounceTimer);
    debounceTimer = setTimeout(() => {
      search((e.target as HTMLInputElement).value);
    }, 300);
  });
  
  // Close on escape
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') {
      hideResults();
      searchInput?.blur();
    }
  });
</script>

<style>
  .search-container {
    max-width: 640px;
    margin: 0 auto;
  }
</style>
