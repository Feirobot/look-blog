---
import { GitHubIcon, TwitterIcon, LinkedInIcon, EmailIcon } from './Icons';

const currentYear = new Date().getFullYear();
---

<footer class="border-t border-[var(--border-light)] bg-[var(--bg-secondary)] mt-16">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <div class="flex flex-col md:flex-row items-center justify-between gap-4">
      <!-- Copyright -->
      <div class="text-center md:text-left">
        <p class="text-sm text-[var(--text-muted)]">
          © {currentYear} Fei's Blog. Made with ❤️ using Astro.
        </p>
      </div>
      
      <!-- Social Links -->
      <div class="flex items-center gap-3">
        <a
          href="https://github.com/yourusername"
          target="_blank"
          rel="noopener noreferrer"
          class="p-2 rounded-lg text-[var(--text-muted)] hover:text-[var(--accent)] hover:bg-[var(--bg-tertiary)] transition-all"
          aria-label="GitHub"
        >
          <span set:html={GitHubIcon()} />
        </a>
        <a
          href="https://twitter.com/yourusername"
          target="_blank"
          rel="noopener noreferrer"
          class="p-2 rounded-lg text-[var(--text-muted)] hover:text-[var(--accent)] hover:bg-[var(--bg-tertiary)] transition-all"
          aria-label="Twitter"
        >
          <span set:html={TwitterIcon()} />
        </a>
        <a
          href="https://linkedin.com/in/yourusername"
          target="_blank"
          rel="noopener noreferrer"
          class="p-2 rounded-lg text-[var(--text-muted)] hover:text-[var(--accent)] hover:bg-[var(--bg-tertiary)] transition-all"
          aria-label="LinkedIn"
        >
          <span set:html={LinkedInIcon()} />
        </a>
        <a
          href="mailto:your@email.com"
          class="p-2 rounded-lg text-[var(--text-muted)] hover:text-[var(--accent)] hover:bg-[var(--bg-tertiary)] transition-all"
          aria-label="Email"
        >
          <span set:html={EmailIcon()} />
        </a>
      </div>
    </div>
  </div>
</footer>
